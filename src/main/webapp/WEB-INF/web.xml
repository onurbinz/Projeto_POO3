<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>ERP Barbershop</display-name>

    <!-- ====================================================== -->
    <!-- JSF 2.3 — Servlet do FacesServlet                       -->
    <!-- ====================================================== -->
    <servlet>
        <servlet-name>FacesServlet</servlet-name>
        <servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>FacesServlet</servlet-name>
        <url-pattern>*.xhtml</url-pattern>
    </servlet-mapping>

    <!-- ====================================================== -->
    <!-- Configurações do JSF                                    -->
    <!-- ====================================================== -->

    <!-- Modo de desenvolvimento (mude para Production em prod) -->
    <context-param>
        <param-name>javax.faces.PROJECT_STAGE</param-name>
        <param-value>Development</param-value>
    </context-param>

    <!-- Charset padrão -->
    <context-param>
        <param-name>javax.faces.FACELETS_ENCODING</param-name>
        <param-value>UTF-8</param-value>
    </context-param>

    <!-- ====================================================== -->
    <!-- PrimeFaces — Tema e configurações                       -->
    <!-- ====================================================== -->
    <context-param>
        <param-name>primefaces.THEME</param-name>
        <param-value>saga</param-value>
    </context-param>
    <context-param>
        <param-name>primefaces.FONT_AWESOME</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- ====================================================== -->
    <!-- Página de boas-vindas                                   -->
    <!-- ====================================================== -->
    <welcome-file-list>
        <welcome-file>index.xhtml</welcome-file>
    </welcome-file-list>

</web-app>
